# SST prod stage — copy to .env.prod and fill in the values
# Run: cp .env.prod.example .env.prod
#
# Deploy order: CertificateStack → AuthStack → ApiStack → SST (this file)
# All values come from CloudFormation outputs after CDK deploy.

# AWS profile to use for local deploys (configured in ~/.aws/config)
AWS_PROFILE=shortify

# Your domain registered in Cloudflare
DOMAIN_NAME=julab-x.space

# ── Cognito ────────────────────────────────────────────────────────────────────
# Source: AWS Console → CloudFormation → AuthStack → Outputs
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Custom Cognito hosted UI domain (without https://)
# DNS CNAME must be added in Cloudflare: auth.julab-x.space → <CognitoDomain output>
NEXT_PUBLIC_COGNITO_DOMAIN=auth.julab-x.space

# Logout redirect — client_id must match NEXT_PUBLIC_COGNITO_CLIENT_ID above
NEXT_PUBLIC_AUTH_LOGOUT_URL=https://auth.julab-x.space/logout?client_id=COGNITO_CLIENT_ID&logout_uri=https://julab-x.space

# ── API Gateway ────────────────────────────────────────────────────────────────
# Custom domain — requires CNAME in Cloudflare: api.julab-x.space → <ApiDomainTarget output>
NEXT_PUBLIC_API_URL=https://api.julab-x.space

# ── ACM Certificate ────────────────────────────────────────────────────────────
# Source: AWS Console → CloudFormation → CertificateStack → Outputs → CertificateArn
# Wildcard cert for *.julab-x.space — must be in us-east-1 (CloudFront requirement)
# Same cert as dev (shared wildcard)
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/CERTIFICATE_ID
