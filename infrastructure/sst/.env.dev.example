# SST dev stage — copy to .env.dev and fill in the values
# Run: cp .env.dev.example .env.dev
#
# Deploy order: CertificateStack → AuthStack → ApiStack → SST (this file)
# All values come from CloudFormation outputs after CDK deploy.

# AWS profile to use for local deploys (configured in ~/.aws/config)
AWS_PROFILE=shortify

# ── Cognito ────────────────────────────────────────────────────────────────────
# Source: AWS Console → CloudFormation → DevAuthStack → Outputs
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Custom Cognito hosted UI domain (without https://)
# DNS CNAME must be added in Cloudflare: dev-auth.julab.space → <CognitoDomain output>
NEXT_PUBLIC_COGNITO_DOMAIN=dev-auth.julab.space

# Logout redirect — client_id must match NEXT_PUBLIC_COGNITO_CLIENT_ID above
NEXT_PUBLIC_AUTH_LOGOUT_URL=https://dev-auth.julab.space/logout?client_id=COGNITO_CLIENT_ID&logout_uri=https://dev.julab.space

# ── API Gateway ────────────────────────────────────────────────────────────────
# Source: AWS Console → CloudFormation → DevApiStack → Outputs → ApiUrl
# Raw execute-api URL (no custom domain needed for dev)
NEXT_PUBLIC_API_URL=https://XXXXXXXXXX.execute-api.eu-central-1.amazonaws.com

# ── ACM Certificate ────────────────────────────────────────────────────────────
# Source: AWS Console → CloudFormation → DevCertificateStack → Outputs → CertificateArn
# Wildcard cert for *.julab.space — must be in us-east-1 (CloudFront requirement)
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/CERTIFICATE_ID
