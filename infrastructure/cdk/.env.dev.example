# CDK dev stage — copy to .env.dev and fill in the values
# Run: cp .env.dev.example .env.dev

STAGE=dev
CDK_DEFAULT_ACCOUNT=           # AWS account ID (12 digits)
CDK_DEFAULT_REGION=eu-central-1

# Your domain registered in Cloudflare
DOMAIN_NAME=julab-x.space

# ARN of the wildcard ACM cert (must be in us-east-1)
# Created by CertificateStack — copy from CloudFormation → DevCertificateStack → Outputs → CertificateArn
# After first deploy: add the DNS validation CNAME from ACM Console to Cloudflare (DNS-only, no proxy)
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/CERTIFICATE_ID

# ── Manual AWS setup required before deploying AuthStack ──────────────────────
# 1. Create SSM parameters in AWS Console (region: CDK_DEFAULT_REGION):
#    /dev/link-shortify/google-client-id    (Type: String)
#    Get credentials from: Google Cloud Console → APIs & Services → Credentials
#    Authorized redirect URI to add in Google: https://dev-auth.julab-x.space/oauth2/idpresponse
#
# 2. After deploying AuthStack — add CNAME in Cloudflare (DNS-only, no proxy):
#    dev-auth.julab-x.space → value from CloudFormation → DevAuthStack → Outputs → CognitoDomain

# Google OAuth client secret — Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=

# ── Upstash Redis (dev database) ──────────────────────────────────────────────
# upstash.com → your dev Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ALERT_EMAIL is not used for dev stage (alarms and budget alerts are prod-only)
