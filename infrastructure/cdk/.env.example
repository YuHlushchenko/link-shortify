# Copy to .env and fill in the values
# Run: cp .env.example .env

STAGE=dev
CDK_DEFAULT_ACCOUNT=           # AWS account ID (12 digits)
CDK_DEFAULT_REGION=eu-central-1

# Your domain registered in Cloudflare
DOMAIN_NAME=julab.space

# ARN of the wildcard ACM cert (must be in us-east-1)
# Created by CertificateStack — copy from CloudFormation → DevCertificateStack → Outputs → CertificateArn
# After deploy: add the DNS validation CNAME from ACM Console to Cloudflare (DNS-only, no proxy)
CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID

# ── Manual AWS setup required before deploying AuthStack ──────────────────────
# 1. Create secret in AWS Secrets Manager (region: CDK_DEFAULT_REGION):
#    Name: dev/link-shortify/google-oauth
#    Keys: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#    Get credentials from: Google Cloud Console → APIs & Services → Credentials
#    Authorized redirect URI to add in Google: https://dev-auth.DOMAIN_NAME/oauth2/idpresponse
#
# 2. After deploying AuthStack — add CNAME in Cloudflare (DNS-only, no proxy):
#    Name: dev-auth  →  Target: value from CloudFormation → DevAuthStack → Outputs → CognitoDomain
