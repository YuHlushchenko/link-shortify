            "Ref": "AlertTopic2720D535",
          },
        ],
        "AlarmDescription": {
          "Fn::Join": [
            "",
            [
              "DynamoDB links table is throttling requests (hot partition).
Check: CloudWatch → DynamoDB → ",
              {
                "Fn::ImportValue": "DynamoStack:ExportsOutputRefLinksTable3D7ED15BED65CECB",
              },
            ],
          ],
        },
        "AlarmName": "link-shortify-dynamo-throttles",
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "Dimensions": [
          {
            "Name": "TableName",
            "Value": {
              "Fn::ImportValue": "DynamoStack:ExportsOutputRefLinksTable3D7ED15BED65CECB",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ThrottledRequests",
        "Namespace": "AWS/DynamoDB",
        "Period": 300,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
