    "Links429Alarm60413199": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlertTopic2720D535",
          },
        ],
        "AlarmDescription": "429 rate limit triggered ≥3 times in 5 min on POST /links.
Access logs: /aws/apigateway/link-shortify",
        "AlarmName": "link-shortify-rate-limit-abuse",
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "EvaluationPeriods": 1,
        "MetricName": "Links429Count",
        "Namespace": "LinkShortify",
        "Period": 300,
        "Statistic": "Sum",
        "Threshold": 3,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "Links429FilterF366F74D": {
      "Properties": {
        "FilterPattern": "{ $.status = "429" && ($.routeKey = "POST /links" || $.routeKey = "POST /links/anonymous") }",
        "LogGroupName": {
          "Ref": "ApiAccessLogGroupCEA70788",
        },
        "MetricTransformations": [
          {
            "DefaultValue": 0,
            "MetricName": "Links429Count",
            "MetricNamespace": "LinkShortify",
            "MetricValue": "1",
          },
        ],
      },
      "Type": "AWS::Logs::MetricFilter",
    },
