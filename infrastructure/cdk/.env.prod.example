# CDK production stage — copy to .env.prod and fill in the values
# Run: cp .env.prod.example .env.prod

STAGE=prod
CDK_DEFAULT_ACCOUNT=           # AWS account ID (12 digits)
CDK_DEFAULT_REGION=eu-central-1

# Your domain registered in Cloudflare
DOMAIN_NAME=julab-x.space

# ARN of the wildcard ACM cert (must be in us-east-1)
# Same cert as dev — copy from CloudFormation → CertificateStack → Outputs → CertificateArn
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/CERTIFICATE_ID

# ── Manual AWS setup required before deploying AuthStack ──────────────────────
# 1. Create SSM parameters in AWS Console (region: CDK_DEFAULT_REGION):
#    /prod/link-shortify/google-client-id    (Type: String)
#    Get credentials from: Google Cloud Console → APIs & Services → Credentials
#    Authorized redirect URI to add in Google: https://auth.julab-x.space/oauth2/idpresponse
#
# 2. After deploying AuthStack — add CNAME in Cloudflare (DNS-only, no proxy):
#    auth.julab-x.space → value from CloudFormation → AuthStack → Outputs → CognitoDomain

# Google OAuth client secret — Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=

# ── Upstash Redis (production database) ───────────────────────────────────────
# upstash.com → your production Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Alerts ────────────────────────────────────────────────────────────────────
# Email for CloudWatch alarms and budget alerts ($0.05/month threshold)
# After deploy: confirm the SNS subscription email AWS sends you
ALERT_EMAIL=
