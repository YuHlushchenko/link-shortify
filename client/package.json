{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "webpack": "5.101.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true yarn build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:style": "stylelint 'src/**/*.{css,scss}'",
    "lint:style:fix": "stylelint 'src/**/*.{css,scss}' --fix",
    "test:unit": "jest --config ./config/jest/jest.config.ts",
    "test:unit:ok": "jest --config ./config/jest/jest.config.ts --updateSnapshot",
    "storybook": "storybook dev -p 6006 --config-dir config/.storybook",
    "storybook:build": "storybook build --config-dir config/.storybook",
    "test:ui": "loki test",
    "test:ui:ok": "loki approve",
    "test:ui:ci": "loki --requireReference --reactUri file:./storybook-static",
    "test:ui:report": "node scripts/generate-visual-json-report.js && reg-cli --from .loki/report.json --report .loki/report.html && echo '✔ Report ready: client/.loki/report.html'",
    "test:ui:json": "node scripts/generate-visual-json-report.js",
    "test:ui:html": "reg-cli --from .loki/report.json --report .loki/report.html"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.71.5",
    "aws-amplify": "^6.17.0",
    "immer": "^10.1.1",
    "next": "16.2.3",
    "next-intl": "^4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hot-toast": "^2.5.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9",
    "@next/bundle-analyzer": "^16",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-links": "^10.4.3",
    "@storybook/addon-onboarding": "^10.4.3",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs-vite": "10.4.3",
    "@storybook/react": "^10.4.3",
    "@storybook/test": "^8.6.15",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/eslint-plugin-query": "^5.71.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-storybook": "10.4.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "loki": "^0.35.1",
    "prettier": "^3.3.3",
    "reg-cli": "^0.17.6",
    "sass": "^1.81.0",
    "sass-loader": "^16.0.3",
    "storybook": "^10.4.3",
    "storybook-next-intl": "^10.1.1",
    "stylelint": "^16.9.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^5.2.0",
    "webpack": "5.101.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  },
  "loki": {
    "configurations": {
      "chrome.laptop": {
        "target": "chrome.docker",
        "width": 1366,
        "height": 768,
        "deviceScaleFactor": 1,
        "mobile": false
      },
      "chrome.tablet": {
        "target": "chrome.docker",
        "width": 768,
        "height": 1024,
        "deviceScaleFactor": 1,
        "mobile": false
      },
      "chrome.iphone7": {
        "target": "chrome.docker",
        "preset": "iPhone 7"
      }
    },
    "diffingEngine": "looks-same"
  }
}
