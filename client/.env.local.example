# Cognito - get from AWS Console → CloudFormation → DevAuthStack → Outputs
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Cognito custom domain (without https://)
# dev:  dev-auth.julab-x.space
# prod: auth.julab-x.space
NEXT_PUBLIC_COGNITO_DOMAIN=dev-auth.julab-x.space

# OAuth callback / logout URLs (must match what's in the UserPoolClient)
NEXT_PUBLIC_AUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback
NEXT_PUBLIC_AUTH_LOGOUT_URL=http://localhost:3000

# API Gateway URL - get from AWS Console → CloudFormation → DevApiStack → Outputs
NEXT_PUBLIC_API_URL=https://XXXXXXXXXX.execute-api.eu-central-1.amazonaws.com
